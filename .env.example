# Database — Supabase Postgres (Transaction pooler URI) or any Postgres
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# Groq — all AI inference (question generation, validation, analysis, reports)
GROQ_API_KEY="your-groq-api-key"
# Optional: override the inference model (default: llama-3.3-70b-versatile).
# Groq rate limits are per-model; free tier is ~100k tokens/day on the 70B model
# (≈ 1-2 full interviews). For a real pilot, enable Groq Dev Tier billing.
# GROQ_MODEL="llama-3.3-70b-versatile"

# Supabase Storage — private buckets for interview videos and report PDFs
# (optional locally: without these, files fall back to ./uploads on disk)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Local file storage fallback (dev only, used when SUPABASE_URL is unset)
UPLOAD_DIR="./uploads"
